{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "MEI Store Product Inventory",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "code": {
          "type": "string",
          "maxLength": 50
        },
        "name": {
          "type": "string",
          "maxLength": 100
        },
        "category": {
          "type": "string",
          "maxLength": 50
        },
        "costPrice": {
          "type": "number"
        },
        "salePrice": {
          "type": "number"
        },
        "stock": {
          "type": "number"
        },
        "minStock": {
          "type": "number"
        },
        "description": {
          "type": "string",
          "maxLength": 500
        },
        "createdAt": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "code",
        "name",
        "category",
        "costPrice",
        "salePrice",
        "stock",
        "minStock",
        "createdAt"
      ]
    },
    "Sale": {
      "title": "Sale",
      "description": "MEI Sales Record",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "date": {
          "type": "string"
        },
        "clientName": {
          "type": "string",
          "maxLength": 100
        },
        "clientPhone": {
          "type": "string",
          "maxLength": 30
        },
        "paymentMethod": {
          "type": "string"
        },
        "total": {
          "type": "number"
        },
        "totalCost": {
          "type": "number"
        },
        "profit": {
          "type": "number"
        },
        "status": {
          "type": "string"
        },
        "notes": {
          "type": "string",
          "maxLength": 500
        }
      },
      "required": [
        "id",
        "date",
        "paymentMethod",
        "total",
        "totalCost",
        "profit",
        "status"
      ]
    },
    "Category": {
      "title": "Category",
      "description": "Product Category",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string",
          "maxLength": 100
        }
      },
      "required": [
        "id",
        "name"
      ]
    }
  },
  "firestore": {
    "/users/{userId}/products/{productId}": {
      "schema": "Product",
      "description": "User's products inventory"
    },
    "/users/{userId}/sales/{saleId}": {
      "schema": "Sale",
      "description": "User's sales transactions"
    },
    "/users/{userId}/categories/{categoryId}": {
      "schema": "Category",
      "description": "User's product categories"
    }
  }
}
