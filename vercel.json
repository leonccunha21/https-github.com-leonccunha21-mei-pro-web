{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/mounjaro", "destination": "/mounjaro.html" },
    { "source": "/mounjaro(.*)", "destination": "/mounjaro.html" },
    { "source": "/manicure", "destination": "/manicure.html" },
    { "source": "/manicure(.*)", "destination": "/manicure.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
